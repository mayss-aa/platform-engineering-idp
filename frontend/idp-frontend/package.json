{
    "name": "idp-frontend",
    "version": "0.0.0",
    "scripts": {
        "ng": "ng",
        "start": "ng serve",
        "build": "ng build",
        "build:prod": "ng build --configuration production",
        "watch": "ng build --watch --configuration development",
        "test": "jest --config jest.config.ts --testPathPattern=src",
        "test:ci": "jest --config jest.config.ts --ci --coverage --testPathPattern=src",
        "lint": "eslint src/",
        "lint:styles": "stylelint \"src/**/*.scss\""
    },
    "prettier": {
        "printWidth": 100,
        "singleQuote": true,
        "overrides": [
            {
                "files": "*.html",
                "options": {
                    "parser": "angular"
                }
            }
        ]
    },
    "private": true,
    "dependencies": {
        "@angular/animations": "20.0.6",
        "@angular/cdk": "20.0.6",
        "@angular/common": "20.0.6",
        "@angular/compiler": "20.0.6",
        "@angular/core": "20.0.6",
        "@angular/forms": "20.0.6",
        "@angular/material": "20.0.6",
        "@angular/platform-browser": "20.0.6",
        "@angular/platform-browser-dynamic": "20.0.6",
        "@angular/router": "20.0.6",
        "zone.js": "~0.15.0",
        "chart.js": "^4.4.0",
        "date-fns": "^3.6.0",
        "highlight.js": "^11.10.0",
        "ng2-charts": "^6.0.0",
        "rxjs": "~7.8.0",
        "tslib": "^2.3.0"
    },
    "devDependencies": {
        "@angular-builders/jest": "20.0.0",
        "@angular-eslint/eslint-plugin": "20.0.0",
        "@angular-eslint/eslint-plugin-template": "20.0.0",
        "@angular-eslint/template-parser": "20.0.0",
        "@angular/build": "20.0.6",
        "@angular/cli": "20.0.6",
        "@angular/compiler-cli": "20.0.6",
        "@testing-library/angular": "^17.3.0",
        "@types/jest": "^29.5.0",
        "@types/node": "^20.17.19",
        "@typescript-eslint/eslint-plugin": "^8.0.0",
        "@typescript-eslint/parser": "^8.0.0",
        "eslint": "^9.0.0",
        "eslint-plugin-boundaries": "^5.0.0",
        "fast-check": "^3.22.0",
        "jest": "^29.7.0",
        "jest-preset-angular": "^14.6.2",
        "stylelint": "^16.11.0",
        "stylelint-config-standard-scss": "^13.1.0",
        "typescript": "~5.8.3"
    }
}
